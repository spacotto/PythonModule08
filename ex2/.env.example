# MATRIX CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual credentials:
# cp env.example .env

# Mode: "development" or "production"
MATRIX_MODE=development

# Connection string for data storage 
DATABASE_URL=postgresql://user:password@localhost:5432/matrix_db

# Secret key for external services (Do not share!)
API_KEY=your_secret_api_key_here

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# URL for the resistance network
ZION_ENDPOINT=https://zion.network.api/v1
